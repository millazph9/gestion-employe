<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ludmi.projet.controller.MainController">

   <top>
      <HBox fx:id="" prefHeight="44.0" prefWidth="600.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Gestion des employés">
               <font>
                  <Font size="18.0" />
               </font>
               <HBox.margin>
                  <Insets left="4.0" top="4.0" />
               </HBox.margin>
            </Label>
            <TextField fx:id="tfSearch" prefHeight="26.0" prefWidth="157.0">
               <HBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
               </HBox.margin>
            </TextField>
            <Button fx:id="buttonSearch" contentDisplay="CENTER" mnemonicParsing="false" onAction="#onSearch" prefHeight="26.0" prefWidth="82.0" text="Rechercher">
               <HBox.margin>
                  <Insets top="5.0" />
               </HBox.margin>
            </Button>
            <BorderPane prefHeight="44.0" prefWidth="156.0">
               <center>
                  <ComboBox fx:id="cbFiltre" prefHeight="28.0" prefWidth="119.0" promptText="Filtre : département" BorderPane.alignment="CENTER" />
               </center>
            </BorderPane>
         </children>
      </HBox>
   </top>
   <center>
      <HBox prefHeight="100.0" prefWidth="600.0" BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="tableEmployes" prefHeight="259.0" prefWidth="603.0">
              <columns>
                <TableColumn fx:id="colPrenom" prefWidth="83.20001220703125" text="Prénom" />
                <TableColumn fx:id="colNom" prefWidth="89.60003662109375" text="Nom" />
                  <TableColumn fx:id="colPoste" prefWidth="94.39996337890625" text="Poste" />
                  <TableColumn fx:id="colDept" prefWidth="111.20001220703125" text="Département" />
                  <TableColumn fx:id="colSalaire" prefWidth="108.0" text="Salaire" />
                  <TableColumn fx:id="colContrat" prefWidth="111.20001220703125" text="Contrat" />

              </columns>
            </TableView>
         </children>
      </HBox>
   </center>
   <bottom>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#onAdd" text="Ajouter" textAlignment="CENTER">
               <HBox.margin>
                  <Insets right="5.0" />
               </HBox.margin>
            </Button>
            <Button fx:id="btnEdit" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#onEdit" text="Modifier " textAlignment="CENTER">
               <HBox.margin>
                  <Insets right="5.0" />
               </HBox.margin>
            </Button>
            <Button fx:id="btnDelete" layoutX="62.0" layoutY="10.0" mnemonicParsing="false" onAction="#onDelete" text="Supprimer">
               <HBox.margin>
                  <Insets right="5.0" />
               </HBox.margin></Button>
            <Button fx:id="btnRead" mnemonicParsing="false" onAction="#onRead" text="Voir">
               <HBox.margin>
                  <Insets right="5.0" />
               </HBox.margin>
            </Button>
            <Button fx:id="btnRead1" mnemonicParsing="false" onAction="#onOut" text="Se deconnecter" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
