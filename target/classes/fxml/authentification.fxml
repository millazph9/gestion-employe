   <children>
      <Label layoutX="248.0" layoutY="124.0" text="CONNEXION">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextField fx:id="tfUser" layoutX="211.0" layoutY="163.0" prefHeight="27.0" prefWidth="177.0" promptText="Identifiant" />
      <TextField fx:id="tfPassword" layoutX="211.0" layoutY="221.0" prefHeight="27.0" prefWidth="177.0" promptText="Mot de passe" />
      <Button layoutX="254.0" layoutY="295.0" mnemonicParsing="false" onAction="#onLogin" text="Se connecter" />
   </children>
</AnchorPane>
